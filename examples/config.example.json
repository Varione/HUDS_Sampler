{
  "project_name": "demo_huds_project",
  "random_seed": 42,
  "variables": [
    {"name": "lx", "min": 0.01, "max": 0.08, "sample_points": 12, "unit": "mm"},
    {"name": "ly", "min": 0.01, "max": 0.10, "sample_points": 12, "unit": "mm"},
    {"name": "lz", "min": 0.01, "max": 0.30, "sample_points": 12, "unit": "mm"},
    {"name": "gap", "min": 0.005, "max": 0.06, "sample_points": 12, "unit": "mm"},
    {"name": "py_val", "min": 0.005, "max": 0.05, "sample_points": 12, "unit": "mm"},
    {"name": "sigma", "min": 20000000, "max": 60000000, "sample_points": 12, "unit": "Pa"},
    {"name": "vx", "min": 10, "max": 1500, "sample_points": 12, "unit": "m_per_sec"}
  ],
  "candidate_pool": {
    "total_samples": 12000,
    "train_ratio": 0.8,
    "validation_ratio": 0.2
  },
  "model": {
    "output_names": ["fx", "fy"],
    "hidden_dim": 128,
    "residual_blocks": 4,
    "dropout": 0.1
  },
  "validation": {
    "default_size": 1000
  },
  "training": {
    "initial_train_size": 256,
    "sample_per_step": 64,
    "max_steps": 10,
    "epochs_per_step": 300,
    "batch_size": 256,
    "learning_rate": 0.001,
    "patience": 30,
    "device": "cuda"
  },
  "huds": {
    "pre_n": 0,
    "repeat_times": 30,
    "topk_ratio": 0.6,
    "batch_size": 256,
    "use_faiss": true
  }
}
