{
  "project_name": "integration_test",
  "random_seed": 42,
  "variables": [
    {"name": "x", "min": 0.0, "max": 1.0, "sample_points": 10, "unit": ""},
    {"name": "y", "min": 0.0, "max": 1.0, "sample_points": 10, "unit": ""}
  ],
  "candidate_pool": {
    "total_samples": 500,
    "train_ratio": 0.8,
    "validation_ratio": 0.2
  },
  "model": {
    "output_names": ["z"],
    "hidden_dim": 64,
    "encoder_blocks": 2,
    "dropout": 0.1
  },
  "validation": {
    "default_size": 50
  },
  "training": {
    "initial_train_size": 32,
    "sample_per_step": 16,
    "max_steps": 3,
    "epochs_per_step": 50,
    "batch_size": 32,
    "learning_rate": 0.001,
    "patience": 15,
    "device": "cpu"
  },
  "huds": {
    "repeat_times": 10,
    "topk_ratio": 0.6,
    "batch_size": 128,
    "use_faiss": false,
    "use_top_p": false,
    "top_p_threshold": 0.9
  }
}
