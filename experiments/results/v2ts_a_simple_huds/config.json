{
  "project_name": "V2TS Simple - Short time series",
  "random_seed": 42,
  "variables": [
    {
      "name": "x_0",
      "min": 0.0,
      "max": 1.0,
      "sample_points": 10,
      "unit": ""
    },
    {
      "name": "x_1",
      "min": 0.0,
      "max": 1.0,
      "sample_points": 10,
      "unit": ""
    },
    {
      "name": "x_2",
      "min": 0.0,
      "max": 1.0,
      "sample_points": 10,
      "unit": ""
    }
  ],
  "candidate_pool": {
    "total_samples": 500,
    "train_ratio": 0.8,
    "validation_ratio": 0.2
  },
  "model": {
    "model_type": "vector_to_time_series",
    "output_names": [
      "ts_0_0",
      "ts_1_0",
      "ts_2_0",
      "ts_3_0",
      "ts_4_0",
      "ts_5_0",
      "ts_6_0",
      "ts_7_0",
      "ts_8_0",
      "ts_9_0",
      "ts_10_0",
      "ts_11_0",
      "ts_12_0",
      "ts_13_0",
      "ts_14_0",
      "ts_15_0",
      "ts_16_0",
      "ts_17_0",
      "ts_18_0",
      "ts_19_0"
    ],
    "hidden_dim": 64,
    "encoder_blocks": 2,
    "dropout": 0.1,
    "seq_len": 20,
