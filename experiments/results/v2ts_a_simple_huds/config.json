    "sample_per_step": 64,
    "max_steps": 5,
    "epochs_per_step": 100,
    "batch_size": 64,
    "learning_rate": 0.001,
    "patience": 20,
    "device": "cuda",
    "retrain_from_scratch": false,
    "restore_optimizer_state": true
